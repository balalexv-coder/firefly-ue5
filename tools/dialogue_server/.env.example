# Скопируйте в .env и при необходимости отредактируйте.

# ---------- Backend selection ----------
# ollama    — локальная модель через Ollama (бесплатно, дефолт для разработки).
# anthropic — Claude API (платно, лучшее качество, для финального демо).
DIALOGUE_BACKEND=ollama

# ---------- Ollama ----------
# Установленные варианты (из `ollama list`):
#   qwen3.5:9b       — 6.6 GB, быстрая, подходит для разработки (дефолт)
#   qwen3.5:9b-q8_0  — 10 GB, менее сжатая квантизация → чуть лучше качество
#   qwen2.5:14b      — 9 GB, средний вариант
#   qwen3.5:35b-a3b  — 23 GB, MoE. Лучшее локальное качество,
#                      но первая загрузка в VRAM долгая.
DIALOGUE_MODEL=qwen3.5:9b
OLLAMA_BASE_URL=http://localhost:11434
DIALOGUE_TEMPERATURE=0.85
DIALOGUE_NUM_PREDICT=700

# ---------- Anthropic (раскомментировать при переключении) ----------
# DIALOGUE_BACKEND=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# DIALOGUE_MODEL=claude-opus-4-7
# DIALOGUE_MAX_TOKENS=800

# ---------- Общее ----------
LOG_DIR=./logs
LOG_LEVEL=INFO
