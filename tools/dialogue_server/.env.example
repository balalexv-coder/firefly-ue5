# Скопируйте в .env и заполните

# Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Модель. Рекомендуется claude-opus-4-7 для лучшего ролевого отыгрыша,
# claude-sonnet-4-6 — ускорить / удешевить.
DIALOGUE_MODEL=claude-opus-4-7

# Максимум токенов в одном ответе (2-3 реплики + 3 опции ~ 400-600 токенов).
DIALOGUE_MAX_TOKENS=800

# Папка для JSONL-логов сессий
LOG_DIR=./logs
